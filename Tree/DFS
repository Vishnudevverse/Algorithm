class Node:
    def __init__(self, val):
        self.val = val
        self.left = None
        self.right = None


# Pre-order: Root, Left, Right
def pre_order_recursive(node):
    if node:
        print(node.val, end=" ")
        pre_order_recursive(node.left)
        pre_order_recursive(node.right)


# In-order: Left, Root, Right
def in_order_recursive(node):
    if node:
        in_order_recursive(node.left)
        print(node.val, end=" ")
        in_order_recursive(node.right)


# Post-order: Left, Right, Root
def post_order_recursive(node):
    if node:
        post_order_recursive(node.left)
        post_order_recursive(node.right)
        print(node.val, end=" ")


# -------------------------------------------


def pre_order_iterative(root):
    if not root:
        return
    stack = [root]
    while stack:
        node = stack.pop()
        print(node.val, end=" ")
        if node.right:
            stack.append(node.right)
        if node.left:
            stack.append(node.left)


def in_order_iterative(root):
    stack = []
    curr = root
    while curr or stack:
        if curr:
            stack.append(curr)
            curr = curr.left
        else:
            curr = stack.pop()
            print(curr.val, end=" ")
            curr = curr.right


def post_order_iterative(root):
    stack = []
    curr = root
    last_visited = None

    while curr or stack:
        if curr:
            stack.append(curr)
            curr = curr.left
        else:
            peek_node = stack[-1]
            # If right child exists and traversing from left child, move right
            if peek_node.right and last_visited != peek_node.right:
                curr = peek_node.right
            else:
                print(peek_node.val, end=" ")
                last_visited = stack.pop()
                curr = None
